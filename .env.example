# bcryptハッシュ。平文パスワードは設定しない。
AUTH_PASSWORD_HASH='$2y$12$replace_with_your_bcrypt_hash'

# 32文字以上のランダム値。未設定ならAI専用APIは起動しない。
AI_API_TOKEN=

# TrueNASでは /mnt/<pool>/apps/omni-money など永続Datasetを指定する。
OMNI_DATA_DIR=./data
OMNI_WEB_BIND_IP=0.0.0.0
OMNI_WEB_PORT=4000
OMNI_AI_PORT=4001

SESSION_MAX_AGE_HOURS=24
TRUSTED_PROXIES=
FORCE_HTTPS=false
HTTPS_REDIRECT_HOST=
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=
